# NJU Table (SeaTable) server URL
SEATABLE_SERVER_URL=https://table.nju.edu.cn

# API Token: Base -> Integrations/API and Webhooks -> API Token
SEATABLE_API_TOKEN=your_api_token_here

# The table name in your base
SEATABLE_TABLE_NAME=报名表

# Column names in the table
COL_NAME=姓名
COL_STUDENT_ID=学号
COL_ITEM=子项

# Limit per item (A/B/C)
ITEM_LIMIT=15

# Optional: comma-separated items
FORM_ITEMS=A,B,C

# Redis distributed lock (recommended for multi-worker gunicorn deployments).
# Leave empty to fall back to threading.Lock (single-process safe only).
# Example: redis://127.0.0.1:6379/0
REDIS_URL=
REDIS_LOCK_KEY=table_signup_lock
REDIS_LOCK_TIMEOUT=10

# Flask runtime
FLASK_HOST=0.0.0.0
FLASK_PORT=8080
FLASK_DEBUG=false
